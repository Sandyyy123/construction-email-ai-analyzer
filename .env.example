OPENAI_API_KEY=your_openai_api_key_here

# Gmail API (optional - if using Gmail source)
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# IMAP (optional - if using IMAP source)
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=your@email.com
IMAP_PASSWORD=your_password

# Microsoft 365 (optional)
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=
MS365_TENANT_ID=

# Email source: gmail | imap | ms365
EMAIL_SOURCE=imap

# Dedup store path
DEDUP_DB_PATH=.tmp/dedup.db

# Output: json_file | api | stdout
OUTPUT_MODE=stdout
OUTPUT_WEBHOOK_URL=
